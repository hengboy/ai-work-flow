{
  "version": 1,
  "roles": [
    {
      "id": "coordinator",
      "name": "Coordinator",
      "description": "负责路由工作、等待受委派结果并汇总结论。",
      "kind": "primary",
      "workspace": "none",
      "delegates": [
        "file-explorer",
        "researcher",
        "document-maintainer",
        "planning-writer",
        "full-stack-coder",
        "git-committer",
        "code-reviewer"
      ],
      "tools": []
    },
    {
      "id": "file-explorer",
      "name": "File Explorer",
      "description": "负责全仓库枚举、搜索和代码地图。",
      "kind": "subagent",
      "workspace": "read",
      "delegates": [],
      "tools": ["Read", "Glob", "Grep", "Bash"]
    },
    {
      "id": "researcher",
      "name": "Researcher",
      "description": "负责研究外部官方资料并报告带引用的发现。",
      "kind": "subagent",
      "workspace": "none",
      "delegates": [],
      "tools": ["WebSearch", "WebFetch"]
    },
    {
      "id": "document-maintainer",
      "name": "Document Maintainer",
      "description": "负责维护项目普通文档。",
      "kind": "subagent",
      "workspace": "write-docs",
      "delegates": [],
      "tools": ["Read", "Edit", "Write", "Bash"]
    },
    {
      "id": "planning-writer",
      "name": "Planning Writer",
      "description": "负责编写计划、ADR、任务拆分、交接和跟踪器文本。",
      "kind": "subagent",
      "workspace": "write-plans",
      "delegates": [],
      "tools": ["Read", "Edit", "Write", "Bash"]
    },
    {
      "id": "full-stack-coder",
      "name": "Full Stack Coder",
      "description": "负责实现源码、测试、必要配置和修复。",
      "kind": "subagent",
      "workspace": "write-code",
      "delegates": [],
      "tools": ["Read", "Edit", "Write", "Glob", "Grep", "Bash"]
    },
    {
      "id": "git-committer",
      "name": "Git Committer",
      "description": "负责受控 Git 提交。",
      "kind": "subagent",
      "workspace": "write-code",
      "delegates": [],
      "tools": ["Read", "Bash"]
    },
    {
      "id": "code-reviewer",
      "name": "Code Reviewer",
      "description": "负责在差异稳定后执行独立的标准审查和规范审查。",
      "kind": "subagent",
      "workspace": "read",
      "delegates": ["review-standards", "review-spec"],
      "tools": ["Read", "Glob", "Grep", "Bash", "Task"]
    },
    {
      "id": "review-standards",
      "name": "Review Standards",
      "description": "负责依据仓库标准审查稳定差异。",
      "kind": "reviewer",
      "workspace": "read",
      "delegates": [],
      "tools": ["Read", "Glob", "Grep", "Bash"]
    },
    {
      "id": "review-spec",
      "name": "Review Spec",
      "description": "负责依据已批准的规范审查稳定差异。",
      "kind": "reviewer",
      "workspace": "read",
      "delegates": [],
      "tools": ["Read", "Glob", "Grep", "Bash"]
    }
  ]
}
